          {
            "tag": "column",
            "width": "weighted",
            "weight": 1,
            "vertical_align": "center",
            "elements": [
              {
                "tag": "button",
                "text": { "tag": "plain_text", "content": "📥 导出数据" },
                "type": "default",
                "width": "fill",
                "behaviors": [
                  { "type": "open_url", "default_url": "__EXPORT_URL__" }
                ]
              }
            ]
          }
        ]
      },
      {
        "tag": "markdown",
        "text_size": "notation",
        "content": "<font color='grey'>📡 数据更新于 __UPDATE_TIME__ · 来源：__SOURCE__</font>"
