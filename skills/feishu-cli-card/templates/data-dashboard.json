          },
          {
            "is_short": true,
            "text": { "tag": "lark_md", "content": "**📦 __METRIC_2_NAME__**\n<font color='green'>__METRIC_2_VALUE__</font>\n<font color='grey'>环比 __METRIC_2_DELTA__</font>" }
          },
          {
            "is_short": true,
            "text": { "tag": "lark_md", "content": "**👥 __METRIC_3_NAME__**\n__METRIC_3_VALUE__\n<font color='grey'>环比 __METRIC_3_DELTA__</font>" }
          },
          {
            "is_short": true,
            "text": { "tag": "lark_md", "content": "**📈 __METRIC_4_NAME__**\n__METRIC_4_VALUE__\n<font color='grey'>环比 __METRIC_4_DELTA__</font>" }
