                "tag": "markdown",
                "content": "**🍰 __CHART_2_TITLE__**"
              },
              {
                "tag": "chart",
                "aspect_ratio": "1:1",
                "chart_spec": {
                  "type": "pie",
                  "data": {
                    "values": [
                      { "分类": "__SEG_1__", "占比": 0 },
                      { "分类": "__SEG_2__", "占比": 0 },
                      { "分类": "__SEG_3__", "占比": 0 }
